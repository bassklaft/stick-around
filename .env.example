# RevenueCat iOS public SDK key (NOT a secret — safe to embed in client builds,
# but kept out of git so test/prod values don't get crossed by accident).
# Find this in the RevenueCat dashboard → Project settings → API keys.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional Android public key — leave blank until Android ships.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
